APP_NAME="Rural AI Doctor"
ENVIRONMENT=production 
DEBUG=False

SECRET_KEY=your-super-secret-production-key-change-me

# --- Database Configuration ---

DATABASE_URL=postgresql+asyncpg://user:password@host:port/database?ssl=require

# --- Google Gemini AI Configuration ---

GOOGLE_API_KEY=your-google-ai-studio-api-key
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-002

# --- LangChain & Agentic Observability ---

LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=rural-ai-doctor-prod
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"

# --- Security & Auth ---
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

BACKEND_CORS_ORIGINS=["https://rural-ai-doctor.vercel.app","http://localhost:3000"]

# --- Infrastructure & Performance ---

REDIS_URL=redis://:password@your-redis-provider.com:6379
RATE_LIMIT_PER_MINUTE=60

# Sentry for python error tracking
SENTRY_DSN=your-sentry-dsn
# Log level management
LOG_LEVEL=INFO

# --- Vector Database (if using external like Pinecone/Weaviate) ---
# VECTOR_DB_API_KEY=your-api-key
# VECTOR_DB_ENVIRONMENT=us-east-1